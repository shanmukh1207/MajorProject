<%layout("/layouts/boilerplate")%>

<body>
  <script>
    const mapToken = "<%= mapToken %>";
    const coordinates = <%- JSON.stringify(listing.geometry.coordinates) %>;
  </script>
  <div class="row mt-3">
    <div class="col-8 offset-3">
      <h3><%=listing.title%></h3>
    </div>

    <div class="card  listing-card col-6 offset-3 show-card">
      <!-- copies design from bootstrap -->
      <img
        src="<%= listing.img.url %>"
        class="card-img-top show-img"
        alt="listing image"
      />
      <div class="card-body">
        <div class="card-text">Owned by <i><%=listing.owner.username %> </i></div>
        <p class="card-text">

          <%=listing.description%>
          <br />
          &#8377;<%=listing.price.toLocaleString("en-IN")%>
          <br />
          <%=listing.location%>
          <br />
          <%=listing.country%>
        </p>
      </div>
    </div>

    
   <% if(currUser && listing.owner._id.equals(currUser._id)) {%>
    <div class="btns mb-3 mt-3">
      <a
        href="/listings/<%=listing._id%>/edit"
        class="btn btn-dark cal-1 offset-3 edit-btn">Edit</a>
      <br />
      <form action="/listings/<%=listing._id%>?_method=DELETE" method="post">
        <button class="btn btn-dark offset-5">Delete</button>
      </form>
    </div>
    <% }%>
  
    <hr />

   
    <div class="row mb-3 mt-3 col-8 offset-3 ">
       <% if(currUser) {%>
      <h4>leave a review</h4>
      <form action="/listings/<%=listing._id %>/reviews" method="post" novalidate class="needs-validation">
        <div mb-3 mt-3>
          <!-- <input
            type="range"
            name="review[rating]"
            id="rating"
            class="form-range"
            range="5"
            min="1"
            max="5"
          /> -->

        </div>
        <div mb-3 mt-3>
        <fieldset class="starability-slot">
 
  <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
  <input type="radio" id="first-rate1" name="review[rating]" value="1" />
  <label for="first-rate1" title="Terrible">1 star</label>
  <input type="radio" id="first-rate2" name="review[rating]" value="2" />
  <label for="first-rate2" title="Not good">2 stars</label>
  <input type="radio" id="first-rate3" name="review[rating]" value="3" />
  <label for="first-rate3" title="Average">3 stars</label>
  <input type="radio" id="first-rate4" name="review[rating]" value="4" />
  <label for="first-rate4" title="Very good">4 stars</label>
  <input type="radio" id="first-rate5" name="review[rating]" value="5" />
  <label for="first-rate5" title="Amazing">5 stars</label>
</fieldset>
</div>
        
        <div class="mb-3">
          <label for="comment" class="form-label" ></label>
          <textarea
           
            name="review[comment]" 
            rows="10"
            cols="5"
            id="review"
            class="form-control"
            required
          ></textarea>
          <div class="invalid-feedback">please add a valied review</div>
        </div>
        
        <button class="btn btn-dark">submit</button>

        <% } %> 
      </form>

      <% if(listing.reviews.length > 0) { %>
      
      <div class="row ">
      <p><b>All reviews</b></p>
     
      
      <% for( review of listing.reviews){ %>

        <div class="card col-5 ms-3 mt-3">
          <div class="card-body">
            <div class="card-title"><b><%=review.author.username%></b></div>
            <p class="starability-result card-text " data-rating="<%= review.rating %>"></p>
            <p class="card-text"><%=review.comment %></p>
           
            
    
            </p>

          </div>
          

          <% if(currUser && review.author._id.equals(currUser._id)) { %>
          <form action="/listings/<%= listing._id %>/reviews/<%=review._id%>?_method=DELETE" method="POST">
            <button class="btn btn-sm btn-dark mb-2">delete</button>
          </form>
          <% } %>
        </div>

        <% } %>

        </div>
         <% } %>
        

        
      
      
    </div>
    <div class="col-8 offset-3 mb-3" >
          <h3>Where you will be </h3>
          <div id="map"></div>
        </div>


   
  </div>
</body>

<script src="/js/map.js"></script>